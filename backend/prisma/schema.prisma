generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Restaurant {
  id        String         @id @default(uuid())
  name      String
  slug      String         @unique
  createdAt DateTime       @default(now())
  orders    OrderEvent[]
  payments  PaymentEvent[]
  scans     ScanEvent[]
}

model WaiterCalls {
  id           String    @id
  restaurantId String
  tableNumber  Int
  status       String    @default("pending")
  createdAt    DateTime  @default(now())
  reachedAt    DateTime?
}

model OrderEvent {
  id           String     @id @default(uuid())
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id])
  tableNumber  String
  items        Json       // Array of { name, price, qty }
  totalPrice     Int        // Total in ₹
  paymentStatus  String     @default("unpaid") // "paid", "unpaid", or "ignore"
  createdAt      DateTime   @default(now())

  @@index([restaurantId])
  @@index([createdAt])
}

model PaymentEvent {
  id           String     @id @default(uuid())
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id])
  tableNumber  String
  amount       Int        // Payment amount in ₹
  items        Json       // Cart snapshot at payment time
  createdAt    DateTime   @default(now())

  @@index([restaurantId])
  @@index([createdAt])
}

model ScanEvent {
  id           String     @id @default(uuid())
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id])
  tableNumber  String?
  createdAt    DateTime   @default(now())

  @@index([restaurantId])
  @@index([createdAt])
}
